# Instagram Graph API credentials
# Get these from https://developers.facebook.com/tools/explorer/

# Your long-lived access token with instagram_content_publish permission
INSTAGRAM_ACCESS_TOKEN=
# Your Instagram Business account's Graph API user ID
# Find it via: GET /me/accounts → page_id → GET /{page-id}?fields=instagram_business_account
INSTAGRAM_USER_ID=

# GitHub credentials (required for local file uploads)
# Create a personal access token at: https://github.com/settings/tokens
# The token needs "Contents" read & write permission on the target repo
GITHUB_TOKEN=
# Repository in "owner/repo" format (e.g. "tomasznocon/instagram-media")
GITHUB_REPO=
