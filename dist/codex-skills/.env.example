# Copy to .env and fill real values.
# Optional machine-specific overrides can be stored in .env.local.

# --- AI media generation (required for generate_image.py / generate_video.py) ---
GEMINI_API_KEY=

# --- Instagram publishing via MCP server ---
INSTAGRAM_ACCESS_TOKEN=
INSTAGRAM_USER_ID=

# Required for local file upload flow before publishing to Instagram.
GITHUB_TOKEN=
GITHUB_REPO=owner/repo

# --- LinkedIn CLI OAuth ---
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=
LINKEDIN_CLI_REDIRECT_URI=http://localhost:3000/callback

# --- Optional LinkedIn CLI overrides ---
# LINKEDIN_CLI_PROFILE=default
# LINKEDIN_CLI_OUTPUT=human
# LINKEDIN_CLI_NO_INPUT=0
